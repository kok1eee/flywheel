#!/usr/bin/env bash
# flywheel — Sensors-first loop engine の CLI。
# state machine を起動・観測・リセットする。state 遷移ロジックは hooks/lib/common.sh に集約。
#
# 注意: `state set` / `_advance` は hook 内部用。auto mode でモデルに撃たせない（C-2 の自己矛盾回避）。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../hooks/lib/common.sh
source "$SCRIPT_DIR/../hooks/lib/common.sh"

usage() {
  cat <<'EOF'
flywheel — Sensors-first loop engine

Usage:
  flywheel start "<適当prompt>" [--eval "<ty/ruff/testコマンド>"] [--no-polish]
        ① goal を記録し設計フェーズ(designing)を開始。実装ゲートが閉じる。
        --eval: 品質チェック(例 "ty check && ruff check && pytest")。--no-polish: simplify steer を無効化
  flywheel adopt "<一言サマリ>" [--eval ..][--no-polish]
        会話 or .claude/journal.md(handoff)で合意済みの方針を結晶化して開始(FR-29)。
        designing の「掘る」をスキップ。design.md はモデルが続けて書く前提
  flywheel status            現在の phase / goal / eval_cmd / 遷移履歴を表示
  flywheel get <jq-filter>   state.json を jq で読む（hook 内部用）
  flywheel reset             state を破棄して dormant に戻す（門が開く）
  flywheel add "<goal>" [--eval ..][--no-polish][--adopt][--notes "<Boundary/曖昧点>"]   backlog に goal を追加（--adopt: next で掘らず結晶化起動＝adopt chain。--notes: /add 軽量 grill の成果を design の種に）
  flywheel list              backlog 一覧
  flywheel backlog rm <n>            backlog の n 番目（list の番号）を削除
  flywheel backlog mv <n> <pos>      backlog の n 番目を pos 位置へ移動（並べ替え）
  flywheel next              dormant/done のとき backlog 先頭を pop して start
  flywheel _advance <to> <by>  phase 遷移（hook 内部用。FLYWHEEL_HOOK=1 必須・手動使用は拒否される）
  flywheel watch-focus "<text>"   監視 council の重点を指定（FR-30 HITL）。overseer が観測者に渡す
  flywheel monitor-set <clean|drift|pending> [level] [reason]
        監視 council（Skill: flywheel:monitor）が verdict を記録する入口（FR-30）。
        drift のとき level = implementing|design|requirements を付ける（design/requirements は人間 hand-back）
  flywheel set-eval "<cmd>"
        現在進行中の goal の eval_cmd を上書きする（出所を explicit に）。phase 不問。
        飛行中（implementing/eval）に done 判定コマンドを直すための入口（gap B 解消）。
  flywheel go
        非コード goal（Bash 運用 / docs のみ）を spec-ready → implementing へ手動昇格（H-1）。
        source 編集が無く design-gate の自動昇格が効かない goal 用。goal 固有の eval
        （set-eval か design.md の完了条件）が必須。designing（設計ゲート閉）では拒否。
  flywheel repos <path>...
        現在の goal に関連する sibling repo を登録（FR-B: diff/polish が宣言リポを合算）。
        引数なしで一覧。列挙したパスで置き換え（FW_ROOT 相対 or 絶対）。登録時に各リポ baseline を捕捉。
        eval は eval_cmd に直接書いて跨ぐ（例 "... && uv run --directory ../lib pytest"）。

フロー: ①prompt → ②設計(designing→spec-ready, validate合格で門開く) → ③自動loop(implementing→eval→done)
門の一時無効化: FLYWHEEL_OFF=1
EOF
}

# goal 系コマンド（start/add）の共通フラグ解析 → PARSED_GOAL/PARSED_EVAL/PARSED_POLISH/PARSED_ENTRY
# --adopt: backlog に「adopt 経路」で積む（next が掘らず結晶化で起動）。start) では使わない（常に掘る）。
_parse_goal_args() {
  PARSED_GOAL=""; PARSED_EVAL=""; PARSED_POLISH="true"; PARSED_ENTRY="start"; PARSED_NOTES=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --eval) PARSED_EVAL="${2:-}"; shift 2 ;;
      --no-polish) PARSED_POLISH="false"; shift ;;
      --adopt) PARSED_ENTRY="adopt"; shift ;;
      --notes) PARSED_NOTES="${2:-}"; shift 2 ;;
      *) PARSED_GOAL="$1"; shift ;;
    esac
  done
}

# goal を起動（start/next/adopt 共通）。前回 plan を退避してから state を初期化。
# $4 entry: "start"（要件を掘る・既定）/ "adopt"（会話/handoff 合意を結晶化・FR-29）。
_start_goal() {  # $1 goal, $2 eval_cmd(空なら自動検出), $3 polish, $4 entry, $5 notes
  local goal="$1" eval_cmd="$2" polish="$3" entry="${4:-start}" notes="${5:-}" detected="" eval_src=""
  if [[ -n "$eval_cmd" ]]; then
    eval_src="explicit"
  else
    eval_cmd="$(fw_detect_eval)"   # --eval 省略時はプロジェクトから検出
    [[ -n "$eval_cmd" ]] && { detected=" (自動検出)"; eval_src="auto"; }
  fi
  fw_archive_plan >/dev/null   # FR-12: 前回の未完了/完了 plan を退避（無ければ no-op）
  fw_init "$goal" "$eval_cmd" "$polish" "$eval_src" "$entry" "$notes"
  if [[ "$entry" == "adopt" ]]; then
    echo "🎯 flywheel adopt: phase=designing（合意を結晶化）"
  else
    echo "🎯 flywheel 開始: phase=designing"
  fi
  echo "   goal: $goal"
  if [[ -n "$eval_cmd" ]]; then echo "   eval_cmd: $eval_cmd$detected"; else echo "   eval_cmd: (なし — done は degrade で stop 許可。--eval で指定可)"; fi
  if [[ "$eval_src" != "explicit" ]]; then
    echo "   ※ design.md の「## 完了条件（eval）」に書いた fenced block が、validate 合格時に eval_cmd へ昇格します（goal 固有の done 定義）"
  fi
  echo "   polish: $polish（実装後に simplify を steer）"
  echo ""
  echo "→ 実装ツール(source への Edit/Write)は今ブロックされています。"
  if [[ "$entry" == "adopt" ]]; then
    echo "→ 会話で合意した方針（無ければ .claude/journal.md 先頭の Next Actions）を plan/design.md に結晶化してください（「## 完了条件（eval）」も設計。掘り直し不要）。"
  else
    echo "→ 先に plan/design.md を書いてください（grill で叩く）。"
  fi
  echo "→ design.md を書くと validate-plan が自動実行され、合格で実装ゲートが開きます。"
  echo "→ 連続自律で回すなら native の /goal も併用推奨（※ /goal は UI コマンド。モデルは起動できないため、ユーザーが打つ）。"
}

# 改善B: backlog の 1-indexed 位置が有効か（整数かつ 1..total）。rm/mv の範囲チェックを集約（rule-of-three）。
# 先頭ゼロを許さない（^[1-9][0-9]*$）: (( )) の8進解釈 と sed/awk の10進解釈の乖離（mv の silent 破損）を防ぐ。
_backlog_int_in_range() { [[ "$1" =~ ^[1-9][0-9]*$ ]] && (( $1 <= ${2:-0} )); }

cmd="${1:-}"; shift || true
case "$cmd" in
  start)
    _parse_goal_args "$@"
    [[ -z "$PARSED_GOAL" ]] && { echo "flywheel start: goal（適当prompt）が必要" >&2; exit 1; }
    _start_goal "$PARSED_GOAL" "$PARSED_EVAL" "$PARSED_POLISH" "start"
    ;;
  adopt)
    # FR-29: 会話 or .claude/journal.md（handoff 経由）で合意済みの方針を designing の
    # 「掘る」をスキップして結晶化する入口。design.md を書くのは続けて動くモデル
    # （会話/journal コンテキストを持つ）。state を作り steer を adopt 用に切り替える。
    _parse_goal_args "$@"
    [[ -z "$PARSED_GOAL" ]] && { echo "flywheel adopt: goal（一言サマリ）が必要" >&2; exit 1; }
    _start_goal "$PARSED_GOAL" "$PARSED_EVAL" "$PARSED_POLISH" "adopt"
    ;;
  add)
    _parse_goal_args "$@"
    [[ -z "$PARSED_GOAL" ]] && { echo "flywheel add: goal が必要" >&2; exit 1; }
    mkdir -p "$FW_DIR"
    jq -cn --arg g "$PARSED_GOAL" --arg e "$PARSED_EVAL" --argjson p "$PARSED_POLISH" --arg entry "$PARSED_ENTRY" --arg notes "$PARSED_NOTES" \
      '{goal:$g, eval_cmd:$e, polish:$p, entry:$entry, notes:$notes}' >> "$FW_BACKLOG"
    echo "📋 backlog に追加（${PARSED_ENTRY}・残 $(fw_backlog_count) 件）: $PARSED_GOAL${PARSED_NOTES:+  [notes 記録済]}"
    ;;
  list)
    [[ -s "$FW_BACKLOG" ]] || { echo "flywheel: backlog は空です"; exit 0; }
    n=0
    while IFS= read -r line; do
      n=$((n + 1))
      g="$(printf '%s' "$line" | jq -r '.goal')"
      e="$(printf '%s' "$line" | jq -r '.eval_cmd // "-"')"
      entry="$(printf '%s' "$line" | jq -r '.entry // "start"')"
      notes="$(printf '%s' "$line" | jq -r '.notes // ""')"
      echo "$n. [$entry] $g  [eval: $e]${notes:+  [notes ✓]}"
    done < "$FW_BACKLOG"
    ;;
  next)
    if fw_state_exists && [[ "$(fw_phase)" != "done" ]]; then
      echo "flywheel: goal 進行中（phase=$(fw_phase)）。完了 or 'flywheel reset' してから next を。" >&2
      exit 1
    fi
    [[ -s "$FW_BACKLOG" ]] || { echo "flywheel: backlog は空です"; exit 0; }
    first="$(head -1 "$FW_BACKLOG")"
    tail -n +2 "$FW_BACKLOG" > "$FW_BACKLOG.tmp" && mv "$FW_BACKLOG.tmp" "$FW_BACKLOG"
    g="$(printf '%s' "$first" | jq -r '.goal')"
    e="$(printf '%s' "$first" | jq -r '.eval_cmd // ""')"
    p="$(printf '%s' "$first" | jq -r 'if .polish == false then "false" else "true" end')"
    entry="$(printf '%s' "$first" | jq -r '.entry // "start"')"   # adopt chain: 積んだ経路で起動（掘る/結晶化）
    notes="$(printf '%s' "$first" | jq -r '.notes // ""')"        # /add 軽量 grill の成果を design の種に引き継ぐ
    echo "▶️ backlog から次の goal を起動（${entry}・残 $(fw_backlog_count) 件）"
    _start_goal "$g" "$e" "$p" "$entry" "$notes"
    ;;
  status)
    if ! fw_state_exists; then echo "flywheel: dormant（state なし。門は開いている）"; exit 0; fi
    echo "phase   : $(fw_phase)"
    echo "goal    : $(fw_get '.goal')"
    echo "eval_cmd: $(fw_get '.eval_cmd')（出所: $(fw_get '.eval_src')）"
    echo "polish  : $(fw_get '.polish')（実施済: $(fw_get '.polished')）"
    echo "veto    : $(fw_get '.veto_count')"
    echo "watch   : focus=$(fw_get '.watch_focus')  monitor=$(fw_get '.monitor.status') $(fw_get '.monitor.level')"
    _repos="$(fw_get '.repos' | jq -rc '[.[]? | "\(.path) (\(.baseline[0:12]))"] | join(", ")' 2>/dev/null || true)"; echo "repos   : ${_repos:--}"
    _notes="$(fw_get '.notes')"; [[ -n "$_notes" ]] && echo "notes   : $_notes"
    echo "history :"
    jq -r '.history[] | "  \(.ts)  \(.from) → \(.to)  [\(.by)]"' "$FW_STATE" 2>/dev/null || true
    ;;
  get)
    [[ $# -lt 1 ]] && { echo "flywheel get: jq filter が必要" >&2; exit 1; }
    fw_get "$1"
    ;;
  watch-focus)
    # FR-30 HITL: 人間が監視 council の重点を指定する。overseer がこれを Read して観測者に渡す。
    # _advance と違い guard しない（人間が随時更新する運用フィールド）。
    fw_state_exists || { echo "flywheel watch-focus: state がありません（先に start）" >&2; exit 1; }
    fw_set_str watch_focus "${1:-}"
    echo "🔎 flywheel watch-focus: ${1:-（クリア）}"
    ;;
  monitor-set)
    # FR-30: 監視 council（Skill: flywheel:monitor）が verdict を記録する入口。
    # status: clean | drift | pending。drift のとき level（implementing/design/requirements）と reason を付ける。
    # 執行（done ブロック / 差し戻し / hand-back）は loop-driver が monitor を読んで行う。
    [[ $# -lt 1 ]] && { echo "flywheel monitor-set <clean|drift|pending> [level] [reason]" >&2; exit 1; }
    fw_state_exists || { echo "flywheel monitor-set: state がありません（先に start）" >&2; exit 1; }
    _ms="$1"; _ml="${2:-}"; _mr="${3:-}"
    # enum 検証（typo verdict で done-gate をすり抜けさせない。loop-driver も未知 status は fail-closed）。
    case "$_ms" in clean|drift|pending) ;; *) echo "flywheel monitor-set: status は clean|drift|pending（受領: '$_ms'）" >&2; exit 1 ;; esac
    case "$_ml" in ""|implementing|design|requirements) ;; *) echo "flywheel monitor-set: level は implementing|design|requirements（受領: '$_ml'）" >&2; exit 1 ;; esac
    [[ "$_ms" == "drift" && -z "$_ml" ]] && { echo "flywheel monitor-set: drift には level（implementing|design|requirements）が必要" >&2; exit 1; }
    # 状態書き込みは fw_set_json（atomic な tmp+mv を集約）に通す。verdict オブジェクトだけ組む。
    fw_set_json monitor "$(jq -cn --arg s "$_ms" --arg l "$_ml" --arg r "$_mr" \
      --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '{status:$s, level:$l, reason:$r, ts:$ts}')"
    echo "🔎 flywheel monitor: status=$_ms${_ml:+ level=$_ml}${_mr:+ reason=$_mr}"
    ;;
  set-eval)
    # gap B: eval_cmd は spec-ready 以降 immutable で、誤った done 判定を飛行中に直せなかった。
    # CLI からの state 書き込みは C-2 の対象外（禁止はモデルによる state.json 直編集のみ）。
    # monitor-set と同型: state があれば phase 不問で eval_cmd/eval_src を上書きする。
    [[ $# -lt 1 ]] && { echo "flywheel set-eval \"<cmd>\"" >&2; exit 1; }
    fw_state_exists || { echo "flywheel set-eval: state がありません（先に start）" >&2; exit 1; }
    # 人間が明示指定した eval なので出所は explicit（go の thick-eval 判定 fw_eval_is_thin=auto も自然に外れる）。
    fw_set_str eval_cmd "$1"
    fw_set_str eval_src "explicit"
    echo "🔧 flywheel eval_cmd を更新: $1（出所: explicit）"
    ;;
  go)
    # H-1: 非コード goal（Bash 運用 / docs のみ）は source 編集が発生しないため、
    # design-gate.sh の「spec-ready で最初の source 編集 → implementing 昇格」が永久に
    # 発火せず spec-ready で詰まる。`go` はその非コード版＝spec-ready→implementing を
    # 手動昇格する正規ルート（偽の source 編集を捏造させない）。eval/veto/polish/monitor/done は
    # 既存 loop-driver に委譲（再利用）。polish は diff≒0 で自動 skip され非コード goal でも無害。
    # CLI からの state 書き込みは C-2 対象外（禁止はモデルの state.json 直編集のみ）。set-eval と同型。
    # usage は記録しない（set-eval/monitor-set も非記録）。evolve は skill-usage.csv を
    # 「スキル名」として読む（grep -v ',steer:' で steer 行だけ除外）ため、裸の "go" 行は無効スキル名のノイズになる。
    fw_state_exists || { echo "flywheel go: state がありません（先に start）" >&2; exit 1; }
    _gp="$(fw_phase)"
    case "$_gp" in
      spec-ready)
        # thick eval 必須: eval_cmd 非空 かつ ! fw_eval_is_thin（eval_src ∈ {explicit, spec}）。
        # 薄い eval（auto = プロジェクト全体の test/lint）/ eval 無しでの空振り done を入口で防ぐ。
        if [[ -z "$(fw_get '.eval_cmd')" ]] || fw_eval_is_thin; then
          echo "🚫 flywheel go: この goal には goal 固有の eval（done 判定）がありません（出所: $(fw_get '.eval_src')）。" >&2
          echo "   go は eval/veto/done を loop-driver に委譲するため、薄い eval だと実装無しでも done になり得ます。" >&2
          echo "   先に goal 固有の done 条件を設定してください:" >&2
          echo "     - flywheel set-eval \"<このgoalの合否コマンド>\"  または" >&2
          echo "     - plan/design.md の「## 完了条件（eval）」に fenced block を書いて validate-plan を通す" >&2
          exit 1
        fi
        fw_advance implementing "flywheel go: non-code goal, no source edit"
        echo "🚀 flywheel go: spec-ready → implementing（非コード goal を loop に載せた）"
        echo "   このまま停止すれば loop-driver が eval（$(fw_get '.eval_cmd')）の exit code で done を判定します。"
        ;;
      no-spec|designing)
        # 設計ゲートが閉じている phase。go を設計スキップの裏口にしない（設計優先思想の根幹）。
        echo "🚫 flywheel go: 現在 $_gp（設計ゲートが閉じています）。go は設計スキップの裏口にはできません。" >&2
        echo "   先に設計を固めて spec-ready にしてください（validate-plan 合格で門が開きます）。" >&2
        exit 1
        ;;
      *)
        # implementing/polish/eval/done: すでに loop に乗っている/終わっている → no-op（情報表示のみ）。
        echo "flywheel go: 現在 $_gp。すでに implementing 以降のため何もしません（go は spec-ready 専用）。"
        ;;
    esac
    ;;
  repos)
    # FR-A マルチレポ: goal に関連する sibling repo を登録。各 path の baseline を登録時に捕捉する。
    # set-eval/monitor-set と同型（fw_state_exists ガード・phase 不問・FLYWHEEL_HOOK なし）。
    # diff/polish 計測が宣言リポを合算する（FR-B）。eval は eval_cmd に直接書いて跨ぐ（本機能はコード未関与）。
    fw_state_exists || { echo "flywheel repos: state がありません（先に start）" >&2; exit 1; }
    if [[ $# -eq 0 ]]; then
      echo "repos:"; fw_get '.repos' | jq -r '.[]? | "  \(.path)  (baseline: \(.baseline[0:12]))"' 2>/dev/null || true
      exit 0
    fi
    _rj="[]"
    for _p in "$@"; do
      _dir="$(fw_repo_dir "$_p")"
      [[ -d "$_dir" ]] || { echo "flywheel repos: ディレクトリが無い: $_p（FW_ROOT 相対 or 絶対）" >&2; exit 1; }
      _b="$(fw_repo_baseline "$_dir")"
      [[ -z "$_b" ]] && echo "⚠️ flywheel repos: $_p は jj/git リポに見えません（baseline 空＝diff 計測は 0 扱い）" >&2
      _rj="$(jq -cn --argjson a "$_rj" --arg p "$_p" --arg b "$_b" '$a + [{path:$p, baseline:$b}]')"
    done
    fw_set_json repos "$_rj"
    echo "🔧 flywheel repos を登録（diff/polish が合算します。列挙したパスで置き換え）:"
    fw_get '.repos' | jq -r '.[]? | "  \(.path)  (baseline: \(.baseline[0:12]))"' 2>/dev/null || true
    ;;
  backlog)
    # 改善B: backlog（未来の goal キュー）の remove/reorder。CLI からの backlog.jsonl 編集は
    # C-2 対象外（禁止はモデルの直編集のみ）。進行中 goal の state.json には触れないので phase ガード不要。
    sub="${1:-}"; shift || true
    case "$sub" in
      rm)
        n="${1:-}"
        [[ -s "$FW_BACKLOG" ]] || { echo "flywheel: backlog は空です" >&2; exit 1; }
        total="$(fw_backlog_count)"
        _backlog_int_in_range "$n" "$total" || { echo "flywheel backlog rm <n>: n は 1..$total（list の番号・受領 '$n'）" >&2; exit 1; }
        removed="$(sed -n "${n}p" "$FW_BACKLOG" | jq -r '.goal')"
        sed "${n}d" "$FW_BACKLOG" > "$FW_BACKLOG.tmp" && mv "$FW_BACKLOG.tmp" "$FW_BACKLOG"
        echo "🗑️ backlog #$n を削除（残 $(fw_backlog_count) 件）: $removed"
        ;;
      mv)
        n="${1:-}"; pos="${2:-}"
        [[ -s "$FW_BACKLOG" ]] || { echo "flywheel: backlog は空です" >&2; exit 1; }
        total="$(fw_backlog_count)"
        { _backlog_int_in_range "$n" "$total" && _backlog_int_in_range "$pos" "$total"; } || { echo "flywheel backlog mv <n> <pos>: n/pos は 1..$total（受領 n=$n pos=$pos）" >&2; exit 1; }
        [[ "$n" == "$pos" ]] && { echo "flywheel backlog mv: #$n は同位置（no-op）"; exit 0; }
        moved_goal="$(sed -n "${n}p" "$FW_BACKLOG" | jq -r '.goal')"
        # n を抜いて pos 位置へ挿入。JSON 行は awk -v を経由させず原文のまま保持する。
        awk -v n="$n" -v pos="$pos" '
          { lines[NR]=$0 }
          END { total=NR; moved=lines[n]; c=0
                for(i=1;i<=total;i++) if(i!=n) rest[++c]=lines[i]
                r=0; for(p=1;p<=total;p++){ if(p==pos) print moved; else print rest[++r] } }
        ' "$FW_BACKLOG" > "$FW_BACKLOG.tmp" && mv "$FW_BACKLOG.tmp" "$FW_BACKLOG"
        echo "↕️ backlog #$n → #$pos へ移動: $moved_goal"
        ;;
      *)
        echo "flywheel backlog <rm <n> | mv <n> <pos>>（閲覧は flywheel list）" >&2; exit 1
        ;;
    esac
    ;;
  reset)
    rm -f "$FW_STATE"
    echo "flywheel: reset 完了（dormant に戻った。門は開いている）"
    ;;
  _advance)
    # C-2 防御: state を進めるのは hook だけ。モデル/人間の直接実行は拒否する。
    # kakuduke の実戦（2026-06-12）でモデルが `_advance done` を直接叩いて eval 判定を
    # 迂回した実例があり、env ガードを追加した。hook（とテスト）は FLYWHEEL_HOOK=1 で呼ぶ。
    if [[ "${FLYWHEEL_HOOK:-}" != "1" ]]; then
      echo "🚫 flywheel _advance: これは hook 内部用です。state はモデルではなく hook が進めます（C-2）。" >&2
      echo "   done にしたいなら: そのまま停止すれば loop-driver が eval（$(fw_get '.eval_cmd')）の exit code で判定します。" >&2
      echo "   goal を中止したいなら: flywheel reset" >&2
      exit 1
    fi
    [[ $# -lt 2 ]] && { echo "flywheel _advance <to> <by>" >&2; exit 1; }
    fw_advance "$1" "$2"
    ;;
  ""|-h|--help|help) usage ;;
  *) echo "flywheel: 不明なコマンド '$cmd'" >&2; usage; exit 1 ;;
esac
